# Uygulama Ayarları
DEBUG=true
APP_NAME=Sinavhazirlama
APP_VERSION=1.0.0
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Veritabanı
DATABASE_URL=sqlite+aiosqlite:///./sinavhazirlama.db
# PostgreSQL için:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sinavhazirlama

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro

# Google Drive (opsiyonel)
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Dosya Yükleme
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
