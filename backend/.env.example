# Uygulama Ayarları
DEBUG=true
APP_NAME=Sinavhazirlama
APP_VERSION=1.0.0
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Veritabanı
# ÖNEMLİ: SQLAlchemy async extension için async driver zorunludur.
# PostgreSQL için asyncpg, SQLite için aiosqlite kullanılmalıdır.
#
# Docker Compose ortamı için (PostgreSQL):
DATABASE_URL=postgresql+asyncpg://admin:password@db:5432/sinavhazirlama
#
# Lokal geliştirme için (SQLite):
# DATABASE_URL=sqlite+aiosqlite:///./sinavhazirlama.db
#
# NOT: postgresql:// veya postgresql+psycopg2:// formatları ÇALIŞMAZ.
# Mutlaka postgresql+asyncpg:// kullanılmalıdır.

# Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-pro

# Google Drive (opsiyonel)
GOOGLE_CREDENTIALS_FILE=credentials.json
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# CORS
# JSON dizi formatı (önerilen):
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
# Virgülle ayrılmış format da kabul edilir:
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Dosya Yükleme
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
