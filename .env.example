# ─────────────────────────────────────────────────────────────────────────────
# Sinavhazirlama – Ortam Değişkenleri Şablonu
# Bu dosyayı kopyalayın: cp .env.example .env
# Ardından .env içindeki değerleri kendi ortamınıza göre güncelleyin.
# ─────────────────────────────────────────────────────────────────────────────

# ── Veritabanı ────────────────────────────────────────────────────────────────
# Docker Compose ile çalıştırırken aşağıdaki değer kullanılır.
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/sinavhazirlama

# PostgreSQL bağlantı bilgileri (docker-compose.yml tarafından okunur)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=sinavhazirlama

# ── Güvenlik ──────────────────────────────────────────────────────────────────
# MUTLAKA değiştirin – en az 32 karakter, rastgele üretilmiş bir değer kullanın.
# Örnek: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-change-in-production

# ── Yapay Zeka (Gemini) ───────────────────────────────────────────────────────
# https://aistudio.google.com adresinden API anahtarı alın.
GEMINI_API_KEY=your-gemini-api-key

# ── Google Drive Entegrasyonu ─────────────────────────────────────────────────
# Google Cloud Console'dan indirilen service account JSON dosyasının yolu.
GOOGLE_CREDENTIALS_FILE=credentials.json
# Oluşturulan dokümanların yükleneceği Drive klasörü (opsiyonel).
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ── Uygulama ──────────────────────────────────────────────────────────────────
# Üretim ortamında false olarak bırakın (Swagger/OpenAPI devre dışı kalır).
DEBUG=false

# ── CORS ──────────────────────────────────────────────────────────────────────
# Virgülle ayırarak birden fazla kaynak belirtilebilir.
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
# React uygulamasının backend API'yi nerede arayacağını belirtir.
VITE_API_URL=http://localhost:8000/api/v1

# ── Dosya Yükleme ─────────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=10
